# LLM API Configuration
# Supports OpenAI, Anthropic (Claude), or any OpenAI-compatible API
# Note: simulations consume significant tokens. Start with <40 rounds.

# Provider: 'openai', 'anthropic', or leave blank for auto-detection
LLM_PROVIDER=anthropic
LLM_BASE_URL=

# For Anthropic (Claude):
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL_NAME=claude-sonnet-4-20250514
# Optional provider-specific key aliases used as fallback when LLM_API_KEY is empty
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# For OpenAI:
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# For OpenAI-compatible providers (e.g., OpenRouter):
# LLM_API_KEY=sk-or-your-key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=anthropic/claude-sonnet-4-20250514

# For Docker + Codex CLI via codex-proxy:
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://codex-proxy:11435/v1
# LLM_API_KEY=codex
# LLM_MODEL_NAME=codex
CODEX_PROXY_WORKERS=4
CODEX_PROXY_TIMEOUT=180

# ===== Graph Database Configuration =====
# KuzuDB (embedded, no external service needed)
GRAPH_BACKEND=kuzu
KUZU_DB_PATH=./data/kuzu_db
# DATA_DIR=./data/json_graphs
# UPLOAD_FOLDER=./backend/uploads

# ===== Backend Server Runtime =====
FLASK_DEBUG=false
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# WAITRESS_THREADS=8
SECRET_KEY=replace_with_a_strong_secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== Tavily Web Search =====
# Required for basic_news_search and basic_web_search tools in the MCP server
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ===== MCP (Model Context Protocol) Tool Server =====
# Enables simulation agents and report agent to call external tools
# via a local MCP server subprocess (stdio transport).
# MCP_SERVER_CMD is the executable to launch (for example: python, node).
# MCP_SERVER_ARGS is a comma-separated argument list.
# Example bundled server:
# MCP_SERVER_CMD=python
# MCP_SERVER_ARGS=-m,mcp_servers.example
MCP_SERVER_ENABLED=true
MCP_SERVER_CMD=python
MCP_SERVER_ARGS=-m,mcp_servers.example
MCP_TOOL_CALL_TIMEOUT=30
MCP_MAX_TOOL_ROUNDS=3
MCP_MAX_TOOLS_PER_AGENT=3

# ===== Task lifecycle safety policy =====
# Auto-accept task offers immediately so assignments start in open state.
TASK_AUTO_ACCEPT_OFFERS=true
TASK_AUTO_ACCEPT_NOTE=Auto-accepted on assignment so work can start immediately.

# Reject new assignments that are created too close to simulation end.
# Example: with 2, a new task requires at least current round + one more round.
TASK_MIN_COMPLETION_ROUNDS=2
TASK_REJECT_LATE_ASSIGNMENTS=true

# Task execution mode: compatibility | mcp_only | required_mcp
TASK_EXECUTION_MODE=compatibility

# Round enforcement mode: disabled | warn | enforce
TASK_ROUND_ENFORCEMENT_MODE=enforce
TASK_ROUND_ENFORCEMENT_ACTION=block
TASK_ROUND_ENFORCEMENT_GRACE_ROUNDS=0

# Offer defaults and urgency/escalation tuning
TASK_DEFAULT_ROUND_BUDGET=3
TASK_DEFAULT_DUE_NEXT_ROUND=true
TASK_IN_PROGRESS_ESCALATION_THRESHOLD=2

# Allow browser mutation endpoints (normally false in agent-managed flows)
ALLOW_BROWSER_TASK_MUTATIONS=false

# ===== Simulation + Report Agent Tuning =====
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5

# OASIS model-call concurrency controls
OASIS_API_SEMAPHORE=8
OASIS_CLI_SEMAPHORE=8

# ===== Accelerated LLM Configuration (optional) =====
# If not using boost config, remove these lines entirely
LLM_BOOST_PROVIDER=
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=

# ===== Frontend (Vite) =====
# API base URL for frontend HTTP client. Leave blank to use same origin.
VITE_API_BASE_URL=
